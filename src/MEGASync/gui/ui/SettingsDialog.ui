  <property name="styleSheet">
   <string notr="true">SettingsDialog
{
background-color: #FFFFFFFF; /*colorToken.page-background*/
color: #ff303233; /*colorToken.text-primary*/
}

#pSecurity QGroupBox, #gGeneral
{
margin-top: 0px;
}

#fLanguageLine, #fThemeLine, #fSleepLine, #fBugReportLine,
#frame, #frame_3,
#fUploadRateLine, #fDownloadRateLine, #fConnectionsLine, #fProxyLine,
#fUploadsDownloadsLine, #fSharesLine, #fContactsLine, #fInfoLine,
#fDefaultFoldersLine, #fCacheLine, #fRemoteCacheLine, #fFileVersionsLine,
#fPermissionsLine
{
background-color: #D8D9DB; /*colorToken.border-strong*/
}

#uploadGroup, #downloadGroup
{
border-radius: 8px;
margin-top: 0px;
}

#eUploadFolder, #eDownloadFolder
{
border-width: 0px;
border-style: none;
padding-left: 4px;
}

#downloadIcon, #uploadIcon
{
border-width: 0px;
border-style: none;
}

#SettingsDialog #pStorageQuota, #SettingsDialog #pTransferQuota
{
background-color:  #E4E4E5; /*colorToken.surface-3*/
}

#SettingsDialog[storageState=&quot;ok&quot;] #pStorageQuota::chunk
{
background-color: #ff09bf5b; /*colorToken.indicator-green*/
}

#SettingsDialog[storageState=&quot;warning&quot;] #pStorageQuota::chunk
{
background-color: #fffb6514; /*colorToken.indicator-orange*/
}

#SettingsDialog[storageState=&quot;full&quot;] #pStorageQuota::chunk
{
background-color: #fff63d6b; /*colorToken.indicator-pink*/
}

#SettingsDialog[transferState=&quot;ok&quot;] #pTransferQuota::chunk
{
background-color: #ff09bf5b; /*colorToken.indicator-green*/
}

#SettingsDialog[transferState=&quot;warning&quot;] #pTransferQuota::chunk
{
background-color: #fffb6514; /*colorToken.indicator-orange*/
}

#SettingsDialog[transferState=&quot;full&quot;] #pTransferQuota::chunk
{
background-color: #fff63d6b; /*colorToken.indicator-pink*/
}

#iconDisabledSyncs
{
image: url(:/error_sync_icon);
}

#lDisabledSyncs
{
color: #ff303233; /*colorToken.text-primary*/
background-color: transparent;
}

#gDisabledSyncError
{
border-width: 0px;
background-color: #ffffe4e8; /*colorToken.notification-error*/
}

#lRecoveryKeyPic
{
border-image: url(:/images/key_pass.png);
min-width: 72px;
min-height: 72px;
}

#lChangePasswordPic
{
border-image: url(:/images/lock.png);
min-width: 72px;
min-height: 72px;
}

#wTabHeader &gt; QToolButton:checked
{
border-color: #ffdd1405; /*colorToken.button-brand*/
font-weight: 600;
}

#wTabHeader &gt; QToolButton
{
padding: 5px 8px 5px 8px;
border-top: 0px;
border-left: 0px;
border-right: 0px;
border-bottom: 3px solid transparent;
background-color: transparent;
color: #ff333333; /*colorToken.text-primary*/
font-size: 10px;
font-weight: 400;
}

#lName
{
font-weight: 600;
}

#LearnMoreContainer, #SelectorsContainer, #ButtonContainer,#widget_6, #widget_21
{
background-color: transparent;
}

#bChangePasswordPic, #bRecoveryKeyPic
{
border: none;
}

#pUsedBandwidth
{
margin-right: 6px;
margin-left: 1px;
}

#cProxyRequiresPassword
{
spacing: 11px;
padding-top: 1px;
padding-bottom: 0px;
}

#lProxyType
{
padding-bottom: -1px;
}

#lHeader
{
background-color: white;
border: none;
}

#lAccountType, #lName
{
font-size: 13px;
background-color: transparent;
}

#lAccountType
{
text-align: left;
border: none;
padding: 0px;
margin: 0px;
color: #ff333333; /*colorToken.text-primary*/
}

#lBandwidthFree
{
color: #0078D7;
}

#lUploadRateLimit, #lDownloadRateLimit, #lProxySettings
{
font-weight: bold;
}

#AddOrRemovedFilesCheck, #NewSharedCheck, #RemovedAccessCheck, #ContactAcceptedCheck, #ContactReminderCheck, #NewContactCheck, #DesktopCheck, #SyncIssuesCheck
{
margin-top: 3px;
margin-bottom: 3px;
}
#bLearnMore
{
padding-left: 0px;
}
#gGeneral
{
border: none
}</string>
